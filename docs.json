{
  "$schema": "https://mintlify.com/docs.json",
  "name": "AdRecon Docs",
  "theme": "almond",
  "colors": {
    "primary": "#1fe467",
    "light": "#8cfa95",
    "dark": "#255237"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/MatthewSabia1/AdRecon"
    },
    "links": [
      {
        "label": "Login",
        "href": "https://app.adrecon.com"
      },
      {
