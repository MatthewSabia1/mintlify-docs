  "keyFeatures": [
    "Real-time ad intelligence feed with 100k+ tracked creatives",
    "Multi-scope viewing (All Ads, Saved Ads, Project-based organization)",
    "Advanced filtering by niche, network, status, and performance",
    "Headless browser-based landing page capture (Page Ripper)",
    "User authentication via Magic Link and Google OAuth",
    "Admin dashboard for user and subscription management",
    "Fanbasis integration for automated user provisioning",
    "Project-based ad organization system",
    "Media proxy for Facebook/Instagram creative assets",
    "Performance analytics and ad lifecycle tracking"
  ],
  "publicApiSurface": [
    "GET /api/ad-media - Media proxy endpoint",
    "POST /api/download-page - Page Ripper capture endpoint",
    "GET /api/admin/users - List and search users",
    "PATCH /api/admin/users - Update user roles",
    "DELETE /api/admin/users - Delete user accounts",
    "POST /api/admin/users - Send password reset emails",
    "GET /api/admin/fanbasis - Fanbasis admin actions",
    "POST /api/admin/fanbasis - Execute Fanbasis operations",
    "POST /api/fanbasis/webhook - Fanbasis webhook handler",
    "public.ads_feed_v2 - Main ad feed view",
    "public.user_saved_ads_feed_v1 - User saved ads view",
    "public.user_project_ads_feed_v1 - Project-scoped ads view"
  ]
